  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter front dev",
    "preview": "pnpm --filter front preview",
    "build": "pnpm --filter front build",
    "convex:local": "node scripts/convex-target.mjs local",
    "convex:prod": "node scripts/convex-target.mjs prod",
    "convex:dev": "node scripts/convex-target.mjs local dev",
